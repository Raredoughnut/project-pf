      "--radius-full",
      "--radius-lg",
      "--radius-md",
      "--radius-sm",
      "--radius-xl",
      "--rd-cream-100",
      "--rd-cream-200",
      "--rd-cream-50",
      "--rd-danger",
      "--rd-dough-200",
      "--rd-dough-400",
      "--rd-dough-600",
      "--rd-dough-800",
      "--rd-dough-900",
      "--rd-orange-300",
      "--rd-orange-500",
      "--rd-orange-600",
      "--rd-sprinkle-grape",
      "--rd-sprinkle-lemon",
      "--rd-sprinkle-mint",
      "--rd-sprinkle-pink",
      "--rd-sprinkle-sky",
      "--rd-success",
      "--rd-warning",
      "--ring",
